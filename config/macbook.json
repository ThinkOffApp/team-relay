{
  "listen": {
    "host": "127.0.0.1",
    "port": 8787
  },
  "queue": {
    "path": "./ide-agent-mb-queue.jsonl"
  },
  "receipts": {
    "path": "./ide-agent-mb-receipts.jsonl",
    "stdout_tail_lines": 80
  },
  "tmux": {
    "default_session": "iak-mb-runner",
    "ide_session": "claudemb",
    "nudge_text": "check rooms",
    "allow": [
      "npm test",
      "npm run build",
      "pytest",
      "git status",
      "git diff"
    ]
  },
  "github": {
    "webhook_secret": "CHANGE_ME",
    "event_kinds": [
      "pull_request",
      "issue_comment"
    ]
  },
  "outbound": {
    "default_webhook_url": ""
  },
  "rate_limit": {
    "message_interval_sec": 30
  },
  "openclaw": {
    "home": "/Users/family/openclaw",
    "bin": "openclaw",
    "ssh": "family@localhost",
    "host": "127.0.0.1",
    "port": 18791,
    "token": "CHANGE_ME"
  },
  "discord": {
    "channels": [
      {
        "id": "1474426061218386094",
        "name": "general"
      },
      {
        "id": "1474427350434189352",
        "name": "agent-puzzles"
      },
      {
        "id": "1474427384945184932",
        "name": "outreach"
      },
      {
        "id": "1474427386693943296",
        "name": "bot-fleet"
      },
      {
        "id": "1474427387621015606",
        "name": "dev"
      }
    ],
    "interval_sec": 30,
    "self_id": "1474422169470636134",
    "skip_bots": false,
    "seen_file": "/tmp/iak-mb-discord-seen.txt"
  },
  "poller": {
    "rooms": [
      "thinkoff-development",
      "ant-farm-management"
    ],
    "api_key": "xfb_a71acdf98be644bd0b015c39cf18dfcff333cc3e4bc83484c2cae9400fde8fcc",
    "handle": "@claudemb",
    "interval_sec": 10,
    "owner_handle": "petrus",
    "ack_enabled": false,
    "seen_file": "/tmp/iak-mb-seen-ids.txt"
  },
  "moltbook": {
    "api_base": "https://www.moltbook.com/api/v1",
    "accounts": [
      {
        "name": "claudemm",
        "api_key": "moltbook_sk_reB71c5cLPjUFaLJ7DEv4F4wrWQ962K0"
      }
    ],
    "default_account": "claudemm"
  },
  "comments": {
    "moltbook": {
      "posts": []
    },
    "github": {
      "repos": [
        {
          "owner": "ThinkOffApp",
          "repo": "ide-agent-kit",
          "type": "issues"
        },
        {
          "owner": "ThinkOffApp",
          "repo": "ClawWatch",
          "type": "issues"
        }
      ]
    },
    "interval_sec": 120,
    "seen_file": "/tmp/iak-mb-comment-seen.txt"
  },
  "automation": {
    "rules": [
      {
        "name": "owner-task-nudge",
        "match": {
          "sender": "petrus",
          "mention": "@claudemm"
        },
        "action": {
          "type": "nudge",
          "text": "check rooms"
        }
      },
      {
        "name": "check-comments-request",
        "match": {
          "sender": "petrus",
          "keywords": [
            "check comments",
            "poll comments",
            "new comments"
          ]
        },
        "action": {
          "type": "nudge",
          "text": "check comments"
        }
      },
      {
        "name": "status-request",
        "match": {
          "sender": "petrus",
          "keywords": [
            "status",
            "how are you"
          ]
        },
        "action": {
          "type": "nudge",
          "text": "check rooms"
        }
      }
    ],
    "cooldown_sec": 10,
    "interval_sec": 15,
    "first_match_only": true,
    "seen_file": "/tmp/iak-mb-automation-seen.txt"
  },
  "acp": {
    "enabled": false,
    "token": "CHANGE_ME",
    "allowed_agents": [
      "@claudemm",
      "@claudemb",
      "@ether"
    ],
    "allowed_harnesses": [],
    "session_timeout_sec": 3600,
    "max_concurrent_sessions": 5,
    "receipt_all_actions": true,
    "sessions_file": "./data/acp-sessions.json"
  }
}
